{
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "tailwindCSS.includeLanguages": {
    "scss": "css"
  },
  "tailwindCSS.experimental.configFile": "src/app/globals.scss",
  "tailwindCSS.classAttributes": [
    "class",
    "className",
    "ngClass",
    "class:list"
  ],
  "editor.quickSuggestions": {
    "strings": "on"
  }
}
